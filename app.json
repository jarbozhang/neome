{
  "expo": {
    "name": "NeoMe",
    "slug": "neome",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.neome.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "NeoMe 需要麦克风权限来进行语音点单",
        "NSCameraUsageDescription": "NeoMe 需要摄像头来追踪您的面部方向，让数字人看向您"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.neome.app",
      "permissions": ["android.permission.RECORD_AUDIO", "android.permission.CAMERA"]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-asset",
      [
        "expo-camera",
        {
          "cameraPermission": "NeoMe 需要摄像头来追踪您的面部方向，让数字人看向您"
        }
      ]
    ]
  }
}
